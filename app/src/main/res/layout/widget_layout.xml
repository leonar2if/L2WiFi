<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="10dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/widget_account_name"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Cuenta"
        android:textColor="#0F1D2D"
        android:textSize="15sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/widget_remaining_time"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="0:00"
        android:textColor="#0F1D2D"
        android:textSize="22sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="2">

        <ImageButton
            android:id="@+id/widget_connect"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:scaleType="center"
            android:contentDescription="Acción izquierda" />

        <ImageButton
            android:id="@+id/widget_balance"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:scaleType="center"
            android:contentDescription="Acción derecha" />
    </LinearLayout>

</LinearLayout>
